{
  "name": "node-self-heallm",
  "version": "0.1.3",
  "description": "Self-healing runtime for Node.js: traceback capture, LLM diff generation, and safe patching.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "self-heal": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist .coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "llm",
    "self-heal",
    "debugging",
    "patch",
    "rag"
  ],
  "repository": {
    "type": "git"
  },
  "sideEffects": false,
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "dotenv": "^16.6.1",
    "fast-glob": "^3.3.3",
    "openai": "^6.0.1",
    "zod": "^4.1.5"
  },
  "optionalDependencies": {
    "@sentry/node": "^10.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  }
}
